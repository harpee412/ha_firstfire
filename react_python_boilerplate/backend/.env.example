# FirstFire Environment Variables Example
# Copy this file to .env and fill in your actual values

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=500

# FirstFire Settings
FIRSTFIRE_DEBUG=false
FIRSTFIRE_SYSTEM_PROMPT="You are a friendly and helpful assistant for Home Assistant setup and configuration. Keep responses concise, practical, and easy to understand."
